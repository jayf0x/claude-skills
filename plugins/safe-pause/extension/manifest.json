{
  "manifest_version": 3,
  "name": "Claude Usage Monitor",
  "version": "1.0.0",
  "description": "Monitors Claude.ai subscription usage and bridges data to Claude Code hooks",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://claude.ai/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Claude Usage Monitor"
  }
}
